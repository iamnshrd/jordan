# Example environment for Jordan Peterson–style agent
# Bind this agent to a separate Telegram bot/account to keep surfaces separate.

AGENT_NAME=jordan-peterson
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_ENABLED=true
# Optional explicit provider/model ref for Jordan runtime + renderer.
# If unset, Jordan falls back to the active OpenClaw agent model.
# For Anthropic API transport, set ANTHROPIC_API_KEY and optionally switch model ref.
JORDAN_MODEL=anthropic/claude-sonnet-4-6
ANTHROPIC_API_KEY=replace_me
